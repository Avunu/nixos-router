{
  "name": "cockpit-router",
  "version": "0.1.0",
  "description": "Cockpit plugin with router views (hosts, Suricata, AdGuard, diagnostics)",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "node build.js",
    "watch": "NODE_ENV=development node build.js",
    "format": "oxfmt src build.js",
    "format:check": "oxfmt --check src build.js",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "lint:typecheck": "oxlint --type-aware -c .oxlintrc.typecheck.json src",
    "typecheck": "tsc",
    "check": "npm run format:check && npm run lint && npm run lint:typecheck && npm run typecheck",
    "upgrade": "npx npm-check-updates -u && npm install"
  },
  "dependencies": {
    "@patternfly/patternfly": "^6.5.2",
    "@patternfly/react-charts": "^8.5.1",
    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-icons": "^6.5.1",
    "@patternfly/react-table": "^6.5.1",
    "ajv": "^8.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "victory": "^37.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "esbuild-sass-plugin": "^3.7.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3"
  }
}
